# Supabase Local Settings
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# DATABASE
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# NODE ENV
NODE_ENV=development

# Cloudflare R2 (ADR-003) — dashboard.cloudflare.com > R2 > Manage API tokens
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=batiaxe-documents

# Bootstrap admin (optionnel — supprimer après première utilisation)
# Permet d'appeler POST /api/v1/admin/promote pour créer le premier admin en prod.
# En local, utiliser supabase/scripts/make-admin.sql directement.
ADMIN_BOOTSTRAP_SECRET=un-secret-long-et-aleatoire

# Phase 4 — Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
NUXT_PUBLIC_SITE_URL=https://bati-axe.com

# Phase 5 — Messagerie (Resend)
RESEND_API_KEY=re_...
